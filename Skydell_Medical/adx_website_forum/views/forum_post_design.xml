<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= POST DESIGN ================= -->
    <template id="post_display_custom"
              inherit_id="website_forum.post_display"
              name="Custom Forum Post Design">

        <!-- WRAP POST CONTENT IN CARD -->
        <xpath expr="//div[contains(@class, 'o_wforum_post_content')]"
               position="before">
            <div class="skd-post-card-start"/>
        </xpath>

        <xpath expr="//div[contains(@class, 'o_wforum_post_content')]"
               position="after">
            <div class="skd-post-card-end"/>
        </xpath>

        <xpath expr="//div[contains(@class, 'btn-toolbar')]"
               position="replace">
            <div class="skd-post-actions o_wforum_vote d-flex align-items-center mt-3"
                 role="toolbar">

                <t t-if="post_id.state == 'active' and post_id.active != False">
                    <t t-set="post" t-value="post_id"/>

                    <!-- Like + Dislike wrapped in .vote for Odoo JS -->
                    <div class="vote d-inline-flex align-items-center me-3">
                        <!-- Like -->
                        <button t-attf-class="skd-flat-btn skd-like-btn vote_up me-1
                                #{ 'skd-like-active' if post_id.user_vote == 1 else '' }
                                #{ 'karma_required opacity-50' if not post_id.can_upvote else '' }"
                                t-att-data-karma="post_id.forum_id.karma_upvote if not post_id.can_upvote else 0"
                                t-attf-data-href="/forum/{{ slug(post_id.forum_id) }}/post/{{ slug(post_id) }}/upvote"
                                t-att-data-can-upvote="1 if post_id.can_upvote else 0"
                                title="Like">
                            <i class="fa fa-thumbs-up me-1"/>
                            <span class="skd-like-count">
                                <t t-esc="post_id.upvote_count or 0"/>
                            </span>
                        </button>

                        <!-- Hidden vote_count keeps Odoo core JS happy -->
                        <span class="vote_count d-none">
                            <t t-esc="post_id.vote_count or 0"/>
                        </span>

                        <!-- Dislike -->
                        <button t-attf-class="skd-flat-btn skd-dislike-btn vote_down ms-1
                                #{ 'skd-dislike-active' if post_id.user_vote == -1 else '' }
                                #{ 'karma_required opacity-50' if not post_id.can_downvote else '' }"
                                t-att-data-karma="post_id.forum_id.karma_downvote if not post_id.can_downvote else 0"
                                t-attf-data-href="/forum/{{ slug(post_id.forum_id) }}/post/{{ slug(post_id) }}/downvote"
                                t-att-data-can-downvote="1 if post_id.can_downvote else 0"
                                title="Dislike">
                            <i class="fa fa-thumbs-down me-1"/>
                            <span class="skd-dislike-count">
                                <t t-esc="post_id.downvote_count or 0"/>
                            </span>
                        </button>
                    </div>
                    <!-- Divider -->
                    <span class="skd-divider me-3"/>
                </t>

                <!-- Comment -->
                <button t-attf-class="skd-flat-btn skd-comment-btn o_wforum_comment me-3
                #{ 'd-none' if not uid else '' }
                #{ 'karma_required opacity-50' if not post_id.can_comment else '' }"
                        t-att-data-karma="post_id.karma_comment if not post_id.can_comment else 0"
                        t-att-data-bs-toggle="'collapse' if post_id.can_comment else None"
                        t-attf-data-bs-target="#comment_forum_post_{{ post_id.id }}"
                        title="Comment">
                    <span class="skd-svg-icon skd-svg-comment me-1">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             viewBox="0 0 120 100" width="28" height="28">
                            <path d="M65 18 Q95 18 105 38 Q115 58 95 72 L92 72 L88 84 L80 72 Q60 72 50 58"
                                  fill="white" stroke="#5a6278"
                                  stroke-width="5"
                                  stroke-linejoin="round"
                                  stroke-linecap="round"/>
                            <path d="M38 10 Q8 10 3 38 Q-2 62 18 76 L20 76 L16 92 L32 80 Q55 84 68 68 Q82 52 72 30 Q62 10 38 10 Z"
                                  fill="#1a56db" stroke="#1a56db"
                                  stroke-width="1.5"
                                  stroke-linejoin="round"/>
                            <circle cx="26" cy="50" r="4.5" fill="#ffffff"/>
                            <circle cx="40" cy="50" r="4.5" fill="#ffffff"/>
                            <circle cx="54" cy="50" r="4.5" fill="#ffffff"/>
                        </svg>
                    </span>
                    <span>
                        <t t-esc="len(post_id.child_ids) if post_id == question else len(post_id.website_message_ids)"/>
                    </span>
                </button>

                <!-- Reply — envelope + precise reference-matching swoosh arrow -->
                <t t-if="post_id == question">
                    <t t-set="user_answer"
                       t-value="uid and post_id.child_ids.filtered(lambda a: a.create_uid.id == uid)"/>
                    <a t-if="not user_answer and uid and question.can_answer and question.state == 'active' and question.active != False"
                       class="skd-flat-btn me-3"
                       data-bs-toggle="collapse"
                       data-bs-target=".answer_collapse"
                       href="#">
                        <span class="skd-svg-icon skd-svg-reply me-1">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                 viewBox="0 0 640 640"  width="26" height="26"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                                <path fill="#5a6278"
                                      d="M125.4 128C91.5 128 64 155.5 64 189.4C64 190.3 64 191.1 64.1 192L64 192L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 192L575.9 192C575.9 191.1 576 190.3 576 189.4C576 155.5 548.5 128 514.6 128L125.4 128zM528 256.3L528 448C528 456.8 520.8 464 512 464L128 464C119.2 464 112 456.8 112 448L112 256.3L266.8 373.7C298.2 397.6 341.7 397.6 373.2 373.7L528 256.3zM112 189.4C112 182 118 176 125.4 176L514.6 176C522 176 528 182 528 189.4C528 193.6 526 197.6 522.7 200.1L344.2 335.5C329.9 346.3 310.1 346.3 295.8 335.5L117.3 200.1C114 197.6 112 193.6 112 189.4z"/>
                            </svg>
                        </span>
                        Reply
                    </a>
                    <a t-if="user_answer" class="skd-flat-btn me-3"
                       t-attf-href="#answer-#{user_answer.id}">
                        <span class="skd-svg-icon skd-svg-reply me-1">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                 viewBox="0 0 640 640"  width="26" height="26"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                                <path fill="#5a6278"
                                      d="M125.4 128C91.5 128 64 155.5 64 189.4C64 190.3 64 191.1 64.1 192L64 192L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 192L575.9 192C575.9 191.1 576 190.3 576 189.4C576 155.5 548.5 128 514.6 128L125.4 128zM528 256.3L528 448C528 456.8 520.8 464 512 464L128 464C119.2 464 112 456.8 112 448L112 256.3L266.8 373.7C298.2 397.6 341.7 397.6 373.2 373.7L528 256.3zM112 189.4C112 182 118 176 125.4 176L514.6 176C522 176 528 182 528 189.4C528 193.6 526 197.6 522.7 200.1L344.2 335.5C329.9 346.3 310.1 346.3 295.8 335.5L117.3 200.1C114 197.6 112 193.6 112 189.4z"/>
                            </svg>
                        </span>
                        View Answer
                    </a>
                </t>

                <!-- Divider -->
                <span class="skd-divider me-3"/>

                <!-- Share -->
                <div class="dropdown me-3">
                    <button class="skd-flat-btn"
                            data-bs-toggle="dropdown"
                            title="Share">
                        <i class="fa fa-paper-plane-o me-1"/>
                        Share
                    </button>
                    <div class="dropdown-menu p-3 skd-share-dropdown">
                        <p class="small text-muted mb-2">Share this post</p>
                        <div class="d-flex gap-3 justify-content-center">
                            <a t-attf-href="https://www.facebook.com/sharer/sharer.php?u={{ request.httprequest.url }}"
                               target="_blank"
                               class="skd-share-icon skd-facebook"
                               title="Share on Facebook">
                                <i class="fa fa-facebook"/>
                            </a>
                            <a t-attf-href="https://twitter.com/intent/tweet?text={{ post_id.name }}&amp;url={{ request.httprequest.url }}"
                               target="_blank"
                               class="skd-share-icon skd-twitter"
                               title="Share on Twitter">
                                <i class="fa fa-twitter"/>
                            </a>
                            <a t-attf-href="https://www.linkedin.com/sharing/share-offsite/?url={{ request.httprequest.url }}"
                               target="_blank"
                               class="skd-share-icon skd-linkedin"
                               title="Share on LinkedIn">
                                <i class="fa fa-linkedin"/>
                            </a>
                            <button class="skd-share-icon skd-copy skd-copy-link-btn"
                                    title="Copy link">
                                <i class="fa fa-link"/>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Three Dots -->
                <t t-if="can_interact_with_post">
                    <t t-call="website_forum.post_dropdown"/>
                </t>


                <!-- RIGHT — Best Answer -->
                <div class="ms-auto d-flex align-items-center gap-2">
                    <t t-if="post_id == answer">
                        <a t-if="question.can_answer and question.forum_id.mode == 'questions'"
                           t-attf-class="skd-flat-btn skd-accept-btn o_wforum_validate_toggler
                           #{ 'skd-accepted' if answer.is_correct else '' }
                           #{ 'karma_required opacity-50' if not post_id.can_accept else '' }"
                           href="#"
                           t-att-data-karma="post_id.karma_accept"
                           t-attf-data-href="/forum/{{ slug(question.forum_id) }}/post/{{ slug(answer) }}/toggle_correct"
                           title="Mark as Best Answer">
                            <i t-attf-class="fa #{ 'fa-check-circle' if answer.is_correct else 'fa-check-circle-o' } me-1"/>
                            <t t-if="answer.is_correct">Best Answer</t>
                            <t t-else="">Mark Best</t>
                        </a>
                    </t>
                </div>

            </div>
        </xpath>

    </template>


    <!-- ================= COMMENT ================= -->
    <template id="post_comment_custom"
              inherit_id="website_forum.post_comment"
              name="Custom Comment UI">

        <xpath expr="//button[hasclass('o_wforum_submit_post')]"
               position="replace">
            <button type="submit"
                    class="o_wforum_submit_post btn skd-send-btn"
                    title="Send comment">
                <i class="fa fa-paper-plane"/>
            </button>
        </xpath>

        <xpath expr="//a[hasclass('btn-link')]" position="replace">
            <span/>
        </xpath>

        <xpath expr="//textarea[@name='comment']" position="replace">
            <textarea name="comment"
                      class="form-control skd-comment-input"
                      rows="1"
                      placeholder="Write a comment..."/>
        </xpath>

    </template>


    <!-- ================= LIST PAGE ================= -->
    <template id="display_post_custom"
              inherit_id="website_forum.display_post">

        <xpath expr="//tr" position="attributes">
            <attribute name="class" add="skd-forum-row" separator=" "/>
        </xpath>

    </template>

    <!-- ================= BOTTOM REPLY BUTTON ================= -->
    <template id="inherit_post_description_reply_btn"
              inherit_id="website_forum.post_description_full"
              name="Custom Bottom Reply Button Icon">

        <xpath expr="//a[contains(@data-bs-target,'.answer_collapse') and .//i[hasclass('fa-reply')]]"
               position="replace">
            <a t-attf-class="skd-flat-btn collapsed #{ 'karma_required opacity-50' if not question.can_answer else '' }#{ ' disabled' if forum.has_pending_post else ''} text-decoration-none"
               t-att-data-karma="question.forum_id.karma_answer"
               data-bs-toggle="collapse"
               data-bs-target=".answer_collapse"
               href="#">
                <span class="skd-svg-icon skd-svg-reply me-1">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 0 640 640"  width="26" height="26"><!--!Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.-->
                        <path fill="#5a6278"
                              d="M125.4 128C91.5 128 64 155.5 64 189.4C64 190.3 64 191.1 64.1 192L64 192L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 192L575.9 192C575.9 191.1 576 190.3 576 189.4C576 155.5 548.5 128 514.6 128L125.4 128zM528 256.3L528 448C528 456.8 520.8 464 512 464L128 464C119.2 464 112 456.8 112 448L112 256.3L266.8 373.7C298.2 397.6 341.7 397.6 373.2 373.7L528 256.3zM112 189.4C112 182 118 176 125.4 176L514.6 176C522 176 528 182 528 189.4C528 193.6 526 197.6 522.7 200.1L344.2 335.5C329.9 346.3 310.1 346.3 295.8 335.5L117.3 200.1C114 197.6 112 193.6 112 189.4z"/>
                    </svg>
                </span>
                Reply
            </a>
        </xpath>

    </template>

</odoo>