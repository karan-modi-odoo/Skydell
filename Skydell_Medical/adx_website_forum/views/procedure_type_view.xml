<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_procedure_type_list" model="ir.ui.view">
        <field name="name">procedure.type.list</field>
        <field name="model">procedure.type</field>
        <field name="arch" type="xml">
            <list string="Procedure Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="is_other" invisible="1"/>
                <field name="specialty_id"/>
            </list>
        </field>
    </record>

    <record id="view_procedure_type_form" model="ir.ui.view">
        <field name="name">procedure.type.form</field>
        <field name="model">procedure.type</field>
        <field name="arch" type="xml">
            <form string="Procedure Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="is_other" invisible="1"/>
                        <field name="sequence" invisible="1"/>
                        <field name="specialty_id"/>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" widget="html"
                               placeholder="Enter a description for this procedure type…"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_procedure_type_search" model="ir.ui.view">
        <field name="name">procedure.type.search</field>
        <field name="model">procedure.type</field>
        <field name="arch" type="xml">
            <search string="Search Procedure Types">
                <field name="name"/>
                <filter string="Archived"
                        name="filter_archived"
                        domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_procedure_type" model="ir.actions.act_window">
        <field name="name">Doctor Procedure Types</field>
        <field name="res_model">procedure.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_procedure_type_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Procedure Type
            </p>
            <p>Define procedure types used in forum posts.</p>
        </field>
    </record>

    <menuitem id="menu_procedure_type"
              name="Procedure Types"
              parent="website.menu_content"
              action="action_procedure_type"
              sequence="52"/>

</odoo>