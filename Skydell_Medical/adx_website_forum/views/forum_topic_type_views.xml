<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_forum_topic_type_list" model="ir.ui.view">
        <field name="name">forum.topic.type.list</field>
        <field name="model">forum.topic.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_forum_topic_type_form" model="ir.ui.view">
        <field name="name">forum.topic.type.form</field>
        <field name="model">forum.topic.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_forum_topic_type" model="ir.actions.act_window">
        <field name="name">Forum Topic Types</field>
        <field name="res_model">forum.topic.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu under Website > Content -->
    <menuitem id="menu_forum_topic_type"
              name="Forum Topic Types"
              parent="website.menu_content"
              action="action_forum_topic_type"
              sequence="50"/>

    <!--
        Admin override: manually toggle Clinical Insight flag.
        Auto-selection happens via the weekly cron (send_weekly_pro_digest).
    -->
    <record id="action_mark_clinical_insight" model="ir.actions.server">
        <field name="name">Toggle Clinical Insight (Admin Override)</field>
        <field name="model_id" ref="website_forum.model_forum_post"/>
        <field name="binding_model_id" ref="website_forum.model_forum_post"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
# Toggle: if all selected are already marked, un-mark; otherwise mark all
all_insight = all(r.is_clinical_insight for r in records)
records.write({'is_clinical_insight': not all_insight})
        </field>
    </record>
</odoo>
