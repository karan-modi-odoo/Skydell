<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_weekly_pro_digest" model="ir.cron">
        <field name="name">Doctor Forum: Weekly Pro Digest</field>
        <field name="model_id" ref="website_forum.model_forum_post"/>
        <field name="state">code</field>
        <field name="code">model.send_weekly_pro_digest()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">weeks</field>
        <!-- [Q6] active=True so cron runs after install -->
        <field name="active" eval="True"/>
    </record>
</odoo>
