<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_rss_feed_fetch" model="ir.cron">
        <field name="name">RSS Feeds: Fetch &amp; Cache Items</field>
        <field name="model_id" ref="adx_rss_feed.model_rss_feed"/>
        <field name="state">code</field>
        <field name="code">model.fetch_all_feeds()</field>
        <field name="interval_number">3</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
