<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_registration_reject_wizard_form" model="ir.ui.view">
        <field name="name">registration.reject.wizard.form</field>
        <field name="model">registration.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Registration">
                <group>
                    <field name="rejection_reason"/>
                </group>

                <footer>
                    <button name="action_confirm_reject"
                            string="Confirm"
                            type="object"
                            class="btn-danger"/>

                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>