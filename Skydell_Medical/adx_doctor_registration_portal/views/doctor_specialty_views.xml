<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_doctor_specialty_tree" model="ir.ui.view">
        <field name="name">doctor.specialty.tree</field>
        <field name="model">doctor.specialty</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Name"/>
            </list>
        </field>
    </record>

    <record id="view_doctor_specialty_form" model="ir.ui.view">
        <field name="name">doctor.specialty.form</field>
        <field name="model">doctor.specialty</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" string="Name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_doctor_specialty" model="ir.actions.act_window">
        <field name="name">Medical Specialties</field>
        <field name="res_model">doctor.specialty</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_doctor_specialty"
              name="Specialties"
              parent="menu_doctor_configuration"
              action="action_doctor_specialty"
              groups="adx_doctor_registration_portal.group_doctor_manager"
              sequence="1"/>
</odoo>
